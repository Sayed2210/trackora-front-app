# Trackora Frontend Environment
# Pilot backend API used during final QA.
# The shared ApiClient currently points at this /v1 API base URL directly.

# Backend API base URL for future environment-based API config
TRACKORA_API_BASE_URL=http://trackora.techlabeg.com/v1

# WebSocket gateway URL
TRACKORA_WS_URL=http://localhost:3000/ws

# Local app URLs
TRACKORA_ADMIN_URL=http://localhost:4200
TRACKORA_MERCHANT_URL=http://localhost:4201
TRACKORA_COURIER_URL=http://localhost:4202

# Feature flags
TRACKORA_SMART_DISPATCH_ENABLED=false
TRACKORA_FRAUD_AUTO_CANCEL_ENABLED=false
TRACKORA_AUTO_BLACKLIST_ENABLED=false
TRACKORA_ROUTE_OPTIMIZATION_ENABLED=false
